<%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
        <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
            All Registered Cable Trays
        </h2>
        
        <% if (cableTray && cableTray.length > 0) { %>
            <ul class="space-y-4">
                <% cableTray.forEach(tray => { %>
                    <li class="bg-gray-100 p-4 rounded-lg shadow-md hover:shadow-lg transition duration-300">
                        <p class="text-lg text-gray-800">Width: <%= tray.cable_tray_width %> mm</p>
                        <p class="text-lg text-gray-800">Height: <%= tray.cable_tray_height %> mm</p>
                        <p class="text-lg text-gray-800">Thickness: <%= tray.cable_tray_thickness %> mm</p>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <div class="text-center py-6">
                <p class="text-gray-600">No cable trays have been added yet.</p>
            </div>
        <% } %>
        
        <div class="mt-8 text-center">
            <a href="/form" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">
                Add New Cable Tray
            </a>
        </div>
    </main>
</body>
</html>