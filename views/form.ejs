<%- include('partials/head') %>

  <body>
    <%- include('partials/nav') %>
      <form action="/formValidated" method="POST" class="container mx-auto mt-6 bg-white p-4 rounded shadow">
        <select name="type" required class="mb-4 p-2 border rounded m-3">
          <option value="">Select Tray Type</option>
          <option value="Raceway">Raceway</option>
          <option value="Ladder">Ladder</option>
          <option value="Cable tray">cable Tray</option>
          <option value="HOT DIP Galvanised Raceway Tray">HOT DIP Galvanised Raceway Tray</option>
          <option value="HOT DIP Galvanised Cable Tray">HOT DIP Galvanised Cable Tray</option>
          <option value="HOT DIP Galvanised Ladder Tray">HOT DIP Galvanised Ladder Tray</option>
         <option value="C-Bend cable tray">C-Bend Cable Tray</option>
        </select>
        <input type="text" name="width" placeholder="Width (mm)" class="input-box" required />
        <input type="text" name="height" placeholder="Height (mm)" class="input-box" required />
        <input type="text" name="thickness" placeholder="Thickness (mm)" class="input-box" required />
        <button type="submit" class=" text-black px-4 py-2 rounded bg-red-400">Submit</button>
      </form>
  </body>

  </html>
