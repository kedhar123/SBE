<%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
        Registered Cable
      </h2>
      <ul class="space-y-4">
        <% cableTray.forEach(tray1 => { %>
          <li class="bg-gray-100 p-4 rounded-lg shadow-md hover:shadow-lg transition duration-300">
            <h6 class="text-lg text-gray-800">Type: <%= tray1.type %></p>
            <p class="text-lg text-gray-800">Width: <%= tray1.width %></p>
            <p class="text-lg text-gray-800">Height: <%= tray1.height %></p>
            <p class="text-lg text-gray-800">Thickness: <%= tray1.thickness %></p>
            <p class="text-lg text-gray-800">Rate: <%= tray1.finalRate %></p>
          </li>
        <% }) %>
      </ul>
    </main>
  </body>
</html>